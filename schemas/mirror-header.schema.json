{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/anrsm/schemas/mirror-header.schema.json",
  "title": "ANRSM File Mirror Header",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "anrsm_version",
    "artifact_type",
    "artifact_id",
    "source_path",
    "source_language",
    "module_id",
    "source_commit",
    "source_fingerprint",
    "semantic_fingerprint",
    "freshness_state",
    "confidence_band",
    "generator_name",
    "generator_version",
    "generated_at"
  ],
  "properties": {
    "anrsm_version": {
      "type": "integer",
      "const": 1
    },
    "artifact_type": {
      "type": "string",
      "const": "file_mirror"
    },
    "artifact_id": {
      "type": "string",
      "pattern": "^file_mirror:.+$"
    },
    "source_path": {
      "type": "string",
      "minLength": 1
    },
    "source_language": {
      "type": "string",
      "minLength": 1
    },
    "module_id": {
      "type": "string",
      "minLength": 1
    },
    "source_commit": {
      "type": "string",
      "minLength": 7
    },
    "source_fingerprint": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_+\\-]+:[A-Fa-f0-9]+$"
    },
    "semantic_fingerprint": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_+\\-]+:[A-Fa-f0-9]+$"
    },
    "freshness_state": {
      "type": "string",
      "enum": [
        "fresh",
        "stale",
        "invalid",
        "unknown"
      ]
    },
    "confidence_band": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "generator_name": {
      "type": "string",
      "minLength": 1
    },
    "generator_version": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "exports": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risk_tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "contracts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "adjacent_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "manual_appendix_present": {
      "type": "boolean"
    }
  }
}
